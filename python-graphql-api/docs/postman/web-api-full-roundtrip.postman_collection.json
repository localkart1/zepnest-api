          "raw": "{\n  \"firstName\": \"Postman\",\n  \"lastName\": \"CustomerUpdated\",\n  \"status\": \"active\",\n  \"internalNotes\": \"updated via postman\",\n  \"addresses\": [\n    {\n      \"id\": \"{{addressId}}\",\n      \"street\": \"2 Updated Street\",\n      \"city\": \"Chennai\",\n      \"zipCode\": \"600002\",\n      \"isPrimary\": true\n    }\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/customers/{{customerId}}",
        "description": "PUT /api/customers/{id} — uses `addressId` from step 6. If `addressId` is empty, clear it in Variables or send a new address without `id`."
      }
