          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Postman\",\n  \"lastName\": \"Technician\",\n  \"email\": \"tech.{{$guid}}@example.test\",\n  \"phone\": \"9700000000\",\n  \"specialization\": [\"plumbing\"],\n  \"experience\": 2,\n  \"status\": \"available\",\n  \"certifications\": [\"DemoCert\"]\n}"
        },
        "url": "{{baseUrl}}/api/technicians",
        "description": "POST /api/technicians — saves `technicianId`."
      }
