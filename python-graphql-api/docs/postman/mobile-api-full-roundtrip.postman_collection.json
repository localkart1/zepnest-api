  "item": [
    {
      "name": "1. Request OTP [200]",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
              "var j = pm.response.json();",
              "if (j.debugOtp) { pm.collectionVariables.set('otp', j.debugOtp); }",
              "pm.test('OTP or debug', function () {",
              "  pm.expect(j.message || j.debugOtp).to.be.ok;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{mobilePhone}}\"\n}"
        },
        "url": "{{baseUrl}}/mobile/auth/request-otp",
        "description": "POST /mobile/auth/request-otp — sets `otp` from `debugOtp` when MOBILE_OTP_DEBUG is enabled; otherwise paste SMS OTP into collection variable `otp`.\n\n**HTTP:** `200` success; `400` invalid phone; `502` SMS failure."
      }
    },
    {
      "name": "2. Verify OTP [200]",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
              "var j = pm.response.json();",
              "pm.expect(j.accessToken, 'accessToken').to.be.ok;",
              "pm.collectionVariables.set('mobileAccessToken', j.accessToken);",
              "if (j.user && j.user.id) pm.collectionVariables.set('userId', j.user.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"{{mobilePhone}}\",\n  \"otp\": \"{{otp}}\",\n  \"firstName\": \"Mobile\",\n  \"lastName\": \"Tester\"\n}"
        },
        "url": "{{baseUrl}}/mobile/auth/verify-otp",
        "description": "POST /mobile/auth/verify-otp — profile bootstrap via firstName/lastName; returns Bearer token.\n\n**HTTP:** `200` JWT issued; `400` missing fields / OTP issue; `401` wrong OTP."
      }
    },
    {
