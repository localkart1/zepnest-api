            "key": "Authorization",
            "value": "Bearer {{mobileAccessToken}}"
          }
        ],
        "url": "{{baseUrl}}/mobile/profile",
        "description": "GET /mobile/profile — user + addresses after registration.\n\n**HTTP:** `GET` `200`; `401`; `404`."
      }
    },
