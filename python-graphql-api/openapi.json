    "/api/orders": {
      "get": {
        "tags": [
          "Orders"
        ],
        "summary": "List orders / bookings (paginated)",
        "parameters": [
          {
            "$ref": "#/components/parameters/Page"
          },
          {
            "$ref": "#/components/parameters/Limit"
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "customerId",
            "in": "query",
            "schema": {
              "type": "integer",
              "description": "Filter by users.user_id"
            }
          },
          {
            "name": "customer_id",
            "in": "query",
            "schema": {
              "type": "integer",
              "description": "Legacy alias for customerId"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated orders"
          }
        }
      },
      "post": {
        "tags": [
          "Orders"
        ],
        "summary": "Create order (booking)",
        "description": "`customerId` or `customer_id` is required and must exist in `users`.\n`status` must match DB `booking_status_enum` if present (default from `BOOKING_STATUS_DEFAULT`).\n",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrderCreate"
              },
              "examples": {
                "minimal": {
                  "value": {
                    "customerId": 5
                  }
                },
                "full": {
                  "value": {
                    "orderNo": "ORD-2026-001",
                    "customerId": 5,
                    "technicianId": null,
                    "address": "12 MG Road",
                    "status": "pending",
                    "subtotal": 1500,
                    "discountAmount": 0,
                    "loyaltyPointsUsed": 0,
                    "totalAmount": 1500,
                    "loyaltyPointsEarned": 0,
                    "isSubscriptionBooking": false,
                    "customerNotes": "Call before visit"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created — includes message, id, orderNo, status"
          },
          "400": {
            "description": "Missing or invalid customerId"
          },
          "404": {
            "description": "Customer user not found"
          }
        }
      }
    },
