  "components": {
    "parameters": {
      "Page": {
        "name": "page",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 1,
          "minimum": 1
        }
      },
      "Limit": {
        "name": "limit",
        "in": "query",
        "schema": {
          "type": "integer",
          "default": 10,
          "minimum": 1
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorMessage"
            }
          }
        }
      },
      "NotFound": {
        "description": "Not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorMessage"
            }
          }
        }
      }
    },
    "schemas": {
      "ErrorMessage": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "WebAuthUser": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "description": "users.user_id"
          },
          "email": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "role": {
            "type": "string",
            "description": "Alias of userType for web frontend compatibility"
          },
          "userType": { "type": "string" }
        }
      },
      "WebAuthSuccess": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT; typ web_user"
          },
          "expiresInHours": { "type": "integer" },
          "user": { "$ref": "#/components/schemas/WebAuthUser" }
        }
      },
      "OrderCreate": {
        "type": "object",
        "required": [],
        "description": "At least one of customerId or customer_id must be present for NOT NULL DB constraints.",
        "properties": {
          "orderNo": {
            "type": "string"
          },
          "customerId": {
            "type": "integer",
            "description": "users.user_id"
          },
          "customer_id": {
            "type": "integer"
          },
          "technicianId": {
            "type": "integer",
            "nullable": true
          },
          "technician_id": {
            "type": "integer",
            "nullable": true
          },
          "address": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "subtotal": {
            "type": "number"
          },
          "discountAmount": {
            "type": "number"
          },
          "loyaltyPointsUsed": {
            "type": "integer"
          },
          "totalAmount": {
            "type": "number"
          },
          "loyaltyPointsEarned": {
            "type": "integer"
          },
          "isSubscriptionBooking": {
            "type": "boolean"
          },
          "customerNotes": {
            "type": "string"
          }
        }
      },
      "CustomerCreate": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "phone": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          }
        }
      },
      "PaginatedCustomers": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "total": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "totalPages": {
            "type": "integer"
          }
        }
      },
      "MobileRequestOtpResponse": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string"
          },
          "expiresInSeconds": {
            "type": "integer"
          },
          "phone": {
            "type": "string"
          },
          "smsSent": {
            "type": "boolean"
          },
          "smsSkipReason": {
            "type": "string"
          },
          "debugOtp": {
            "type": "string",
            "description": "Only if MOBILE_OTP_DEBUG=true"
          }
        }
      },
      "MobileVerifyOtpResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "tokenType": {
            "type": "string",
            "example": "Bearer"
          },
          "expiresInSeconds": {
            "type": "integer"
          },
          "user": {
            "type": "object"
          }
        }
      },
      "MobileBookingCreate": {
        "type": "object",
        "required": [
          "serviceAddress"
        ],
        "properties": {
          "serviceAddress": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "serviceId": {
            "type": "integer"
          },
          "serviceIds": {
            "type": "array",
            "items": {
              "type": "integer"
            }
          },
          "description": {
            "type": "string"
          },
          "voiceNoteUrl": {
            "type": "string"
          },
          "videoUrl": {
            "type": "string"
          },
          "customerNotes": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT in `Authorization: Bearer <token>`. **Mobile:** `accessToken` from `POST /mobile/auth/verify-otp` (`typ: mobile_customer`). **Web:** `accessToken` from `POST /api/auth/login` or `/api/auth/register` (`typ: web_user`)."
      }
    }
  }
}