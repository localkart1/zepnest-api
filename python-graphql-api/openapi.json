{
  "openapi": "3.0.3",
  "info": {
    "title": "Zepnest API (Web + Mobile)",
    "description": "JSON REST API under `/api` for the admin portal (customers, technicians, orders, services, catalog, subscriptions, payments).\n**Web auth (email/password):** `POST /api/auth/register`, `POST /api/auth/login`, `GET /api/auth/me` (JWT `typ: web_user`).\nGraphQL remains at `/graphql` (not included in this document).\n\n\n**Mobile** routes are under `/mobile` (JWT Bearer after verify-otp). GraphQL at `/graphql` is not included.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5002",
      "description": "Default local (see `PORT` in `.env`)"
    },
    {
      "url": "/",
      "description": "Same origin as this server"
    }
  ],
  "tags": [
    {
      "name": "Auth"
    },
    {
      "name": "Customers"
    },
    {
      "name": "Technicians"
    },
    {
      "name": "Assets"
    },
    {
      "name": "Orders"
    },
    {
      "name": "Services"
    },
    {
      "name": "Catalog"
    },
    {
      "name": "Subscriptions"
    },
    {
      "name": "Enumerations"
    },
    {
      "name": "Dashboard"
    },
    {
      "name": "Payments"
    },
    {
      "name": "Settings"
    },
    {
      "name": "Mobile — Auth"
    },
    {
      "name": "Mobile — Home"
    },
    {
      "name": "Mobile — Catalog"
    },
    {
      "name": "Mobile — Bookings"
    },
    {
      "name": "Mobile — Profile"
    },
    {
      "name": "Mobile — Addresses"
    },
    {
      "name": "Mobile — Uploads"
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register with email and password (web)",
        "description": "Stores a Werkzeug hash in `users.password_hash`. New accounts are `user_type=customer`. Email is normalized to lowercase.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": {
                    "type": "string",
                    "minLength": 8,
                    "description": "Plain text; stored hashed"
                  },
                  "firstName": { "type": "string" },
                  "lastName": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created; JWT returned",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WebAuthSuccess" }
              }
            }
          },
          "400": { "description": "Validation error" },
          "409": { "description": "Email already registered" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login with email and password (web)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "JWT issued",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WebAuthSuccess" }
              }
            }
          },
          "400": { "description": "Missing fields" },
          "401": { "description": "Invalid credentials or inactive user" }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Current user (web JWT)",
        "description": "Use **Authorize** with the `accessToken` from `/api/auth/login` or `/api/auth/register`. Token payload includes `typ: web_user` (not the same as mobile OTP JWTs).",
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "user": { "$ref": "#/components/schemas/WebAuthUser" }
                  }
                }
              }
            }
          },
          "401": { "description": "Missing or invalid token" }
        }
      }
    },
    "/api/customers": {
      "get": {
        "tags": [
          "Customers"
        ],
        "summary": "List customers (paginated)",
        "description": "Uses `items` as the primary list key.\nLegacy `data` is not returned on this endpoint anymore.\n",
        "parameters": [
          {
            "$ref": "#/components/parameters/Page"
          },
          {
            "$ref": "#/components/parameters/Limit"
          },
          {
            "name": "search",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "active",
                "inactive"
              ]
            }
          },
          {
            "name": "customerUserType",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "sortBy",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "id",
                "createdAt",
                "updatedAt",
                "firstName",
                "lastName",
                "email",
                "phone"
              ]
            }
          },
          {
            "name": "sortField",
            "in": "query",
            "schema": {
              "type": "string",
              "description": "Alias for sortBy"
            }
          },
          {
            "name": "sortOrder",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "asc",
                "desc"
              ],
              "default": "desc"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Paginated list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PaginatedCustomers"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Customers"
        ],
        "summary": "Create customer",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CustomerCreate"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
