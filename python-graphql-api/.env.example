# =============================================================================
# Zepnest API — local environment (do not commit; add .env to .gitignore)
# =============================================================================

# --- Flask ---
FLASK_ENV=development
FLASK_DEBUG=True

# --- HTTP server (main.py default 5002) ---
PORT=5002

# --- Security (sessions, JWT, OTP hashing) ---
SECRET_KEY=your-secret-key-here

# --- Database ---
# SQLite (quick local dev):
# DATABASE_URL=sqlite:///app.db
#
# PostgreSQL:
DATABASE_URL=postgresql://<username>:<password>@<pub_ip>:5432/zn_test

DB_SCHEMA=public
AUTO_CREATE_TABLES=false

# --- HTTP request log (stdout via Flask logger; JSON line per request) ---
REQUEST_LOG_ENABLED=true
# Max chars for payload preview in logs
REQUEST_LOG_BODY_MAX=4000
# On 4xx/5xx: max chars for URL query_string and parsed query JSON; response_body_preview cap
# REQUEST_LOG_ERROR_QUERY_MAX=8000
# REQUEST_LOG_ERROR_RESPONSE_MAX=800
# Comma-separated paths to skip (e.g. noisy health probes): /health/apis,/
# REQUEST_LOG_SKIP_PATHS=

# --- Bookings / PostgreSQL enum `booking_status_enum` (must match DB labels) ---
BOOKING_STATUS_DEFAULT=pending
BOOKING_STATUS_OPEN=pending,open,under_review
BOOKING_STATUS_PIPELINE=pending,under_review,assigned,in_progress,open
BOOKING_STATUS_ASSIGNED=assigned
# Label must exist on ``booking_status_enum`` for escalate + any row stored as escalated.
BOOKING_STATUS_ESCALATED=escalated

# =============================================================================
# Mobile REST (`/mobile`) — OTP + JWT
# =============================================================================

MOBILE_OTP_TTL_SECONDS=300
MOBILE_JWT_EXPIRES_HOURS=168
# Local only: include debugOtp in request-otp response (never in production).
MOBILE_OTP_DEBUG=false

# =============================================================================
# 2Factor.in — SMS for `POST /mobile/auth/request-otp`
# https://2factor.in — India: DLT + template + sender in dashboard
# =============================================================================

SMS_2FACTOR_API_KEY=28e3fafe-2a87-11f1-bcb0-0200cd936042
SMS_2FACTOR_ENABLED=true
SMS_2FACTOR_TIMEOUT_SECONDS=15

# =============================================================================
# AWS S3 — presigned uploads (voice/video URLs on bookings)
# =============================================================================

AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_S3_ENDPOINT_URL=
# AWS_S3_PUBLIC_BASE_URL=

AWS_S3_VOICE_PREFIX=mobile/voice/
AWS_S3_VIDEO_PREFIX=mobile/video/
AWS_S3_PRESIGN_EXPIRES=3600
AWS_S3_ADDRESSING_STYLE=auto
AUDIT_LOG_ENABLED=true