FLASK_ENV=development
FLASK_DEBUG=True
# SQLite (quick local dev):
# DATABASE_URL=sqlite:///app.db
#   
# Local Postgres (recommended for existing schemas):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/your_db_name
DATABASE_URL=postgresql://postgres:edrmsK24WjqL@localhost:5432/zn_test
DB_SCHEMA=public
AUTO_CREATE_TABLES=false
SECRET_KEY=your-secret-key-here
PORT=5000

# Mobile app (/mobile): OTP + JWT
# MOBILE_OTP_TTL_SECONDS=300
# MOBILE_JWT_EXPIRES_HOURS=168
# MOBILE_OTP_DEBUG=true

# --- AWS S3 (mobile voice/video uploads; fill in when ready) ---
# Bucket is required for POST /mobile/uploads/presign. Credentials optional if using IAM role.
AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional (temporary creds / assumed role):
# AWS_SESSION_TOKEN=
# Optional: MinIO / LocalStack / custom S3-compatible API
# AWS_S3_ENDPOINT_URL=
# Optional: CloudFront or public CDN base URL for object GET (no trailing slash)
# AWS_S3_PUBLIC_BASE_URL=
# Key prefixes inside the bucket (include trailing slash)
# AWS_S3_VOICE_PREFIX=mobile/voice/
# AWS_S3_VIDEO_PREFIX=mobile/video/
# Presigned PUT lifetime in seconds
# AWS_S3_PRESIGN_EXPIRES=3600
# S3 addressing: auto | path | virtual
# AWS_S3_ADDRESSING_STYLE=auto
