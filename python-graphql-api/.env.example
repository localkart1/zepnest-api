# =============================================================================
# Zepnest API — environment template
# Copy this file to `.env` and fill in values. Do not commit `.env`.
# =============================================================================

# --- Flask ---
FLASK_ENV=development
FLASK_DEBUG=True

# --- HTTP server (main.py default is 5002 if unset) ---
PORT=5002

# --- Security ---
# Used for sessions, JWT signing, and OTP hashing — use a long random string in production.
SECRET_KEY=change-me-to-a-long-random-string

# Web email/password login (`POST /api/auth/login`, `register`). JWT lifetime in hours. Default 24.
# WEB_JWT_EXPIRES_HOURS=24

# --- Database ---
# SQLite (quick local dev):
# DATABASE_URL=sqlite:///app.db
#
# PostgreSQL (recommended for production / existing schemas):
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME

# Postgres: optional schema search path (see api/__init__ engine options).
DB_SCHEMA=public

# If true, SQLAlchemy may create tables on startup (Postgres usually false when using existing DB).
AUTO_CREATE_TABLES=false

# Capture API-driven INSERT/UPDATE/DELETE statements into `audit_logs` table.
# If the table does not exist, API responses still work (logging is best-effort).
AUDIT_LOG_ENABLED=true
# Postgres: inserts use `public.audit_logs` by default so audit rows land in `public` even if
# DB_SCHEMA is a different schema. Override with two-part name only, e.g. myschema.audit_logs
# AUDIT_LOG_TABLE=public.audit_logs
# Set true to log failed audit inserts to the server console (helps when rows never appear).
# AUDIT_LOG_DEBUG=false
#
# If ``table_name`` looks empty or does not match filters, search raw SQL:
#   SELECT occurred_at, table_name, request_path FROM public.audit_logs
#   WHERE sql_text ILIKE '%bookings%' OR sql_text ILIKE '%booking_items%'
#   ORDER BY occurred_at DESC LIMIT 20;

# --- Bookings / PostgreSQL enum ``booking_status_enum`` ---
# Labels must match your DB. Defaults align with enums that use ``pending`` / ``assigned`` / ``escalated``.
# BOOKING_STATUS_DEFAULT=pending
# Comma-separated lists (no spaces required):
# BOOKING_STATUS_OPEN=pending,open,under_review
# BOOKING_STATUS_PIPELINE=pending,under_review,assigned,in_progress,open
# BOOKING_STATUS_ASSIGNED=assigned

# =============================================================================
# Mobile REST API (`/mobile`) — OTP login + JWT
# =============================================================================

# OTP validity window (seconds). Default 300.
MOBILE_OTP_TTL_SECONDS=300

# JWT lifetime for `Authorization: Bearer` after verify-otp (hours). Default 168.
MOBILE_JWT_EXPIRES_HOURS=168

# If true, `POST /mobile/auth/request-otp` may include `debugOtp` in JSON (local testing only).
MOBILE_OTP_DEBUG=false

# =============================================================================
# 2Factor.in — SMS delivery for `POST /mobile/auth/request-otp`
# Dashboard: https://2factor.in — API docs: https://2factor.in/API/DOCS/SMS_OTP.html
# After signup: add API key + wallet; India sends require DLT + OTP template + Sender ID in dashboard.
# =============================================================================

SMS_2FACTOR_API_KEY=

# true = send SMS when `SMS_2FACTOR_API_KEY` is set. Set false to skip SMS but keep key (e.g. staging).
SMS_2FACTOR_ENABLED=true

# HTTP timeout (seconds) when calling 2Factor.
SMS_2FACTOR_TIMEOUT_SECONDS=15

# Optional: OTP template name from 2Factor dashboard (append as extra URL segment after OTP).
# Required for some DLT-approved custom SMS templates. Leave empty for default SMS OTP.
# SMS_2FACTOR_TEMPLATE_NAME=

# Troubleshooting — user gets a voice call instead of SMS:
# - This app only calls the SMS API (path contains /SMS/). Voice OTP uses /VOICE/ (different URL).
# - In 2Factor.in: confirm the API key is for SMS OTP, wallet balance, DLT-approved SMS template,
#   and Sender ID. If SMS is blocked or misconfigured, some accounts may behave unexpectedly; check 2Factor delivery logs / support.

# =============================================================================
# AWS S3 — presigned uploads for mobile voice/video (see `api/s3_config.py`)
# =============================================================================

AWS_S3_BUCKET=
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional: temporary credentials / assumed role.
# AWS_SESSION_TOKEN=

# Optional: MinIO, LocalStack, or other S3-compatible endpoint.
# AWS_S3_ENDPOINT_URL=

# Optional: public base URL for GET objects (no trailing slash).
# AWS_S3_PUBLIC_BASE_URL=

# Object key prefixes (include trailing slash).
AWS_S3_VOICE_PREFIX=mobile/voice/
AWS_S3_VIDEO_PREFIX=mobile/video/

# Presigned PUT expiry (seconds).
AWS_S3_PRESIGN_EXPIRES=3600

# S3 addressing style: auto | path | virtual
AWS_S3_ADDRESSING_STYLE=auto